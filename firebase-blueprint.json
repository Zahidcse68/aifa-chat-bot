{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task in the user's schedule.",
      "type": "object",
      "properties": {
        "id": { "type": "number", "description": "Unique identifier for the task" },
        "text": { "type": "string", "description": "The text of the task" },
        "done": { "type": "boolean", "description": "Whether the task is completed" },
        "time": { "type": "string", "description": "Scheduled time in HH:MM format" },
        "alarmTriggered": { "type": "boolean", "description": "Whether the alarm has been triggered" },
        "userId": { "type": "string", "description": "The ID of the user who owns the task" }
      },
      "required": ["id", "text", "done", "userId"]
    },
    "UserPreferences": {
      "title": "User Preferences",
      "description": "User preferences for AIFA OS.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user" },
        "userName": { "type": "string", "description": "The name of the user" },
        "faceEnrolled": { "type": "boolean", "description": "Whether the user has enrolled their face" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks belonging to a specific user."
    },
    "/users/{userId}/preferences/default": {
      "schema": { "$ref": "#/entities/UserPreferences" },
      "description": "Preferences for a specific user."
    }
  }
}
